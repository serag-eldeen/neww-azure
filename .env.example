# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# CLINIC_PASSCODE: The distinct clinic-wide PIN/passcode for front-desk/PIN-pad kiosk login.
# Default: 2026
CLINIC_PASSCODE="2026"

# DATABASE_URL: The connection string for your remote PostgreSQL database.
# Configure this in the secrets manager if you wish to use remote PostgreSQL persistence.
# Example format: postgresql://username:password@hostname:5432/dbname
DATABASE_URL=

# JWT_SECRET: The secret key for signing secure JWT access tokens in production.
JWT_SECRET=

# JWT_REFRESH_SECRET: The secret key for signing secure JWT refresh tokens in production.
JWT_REFRESH_SECRET=

# NODE_ENV: Set to "production" in live deployment to enable strict checks and optimize the production build.
NODE_ENV="production"

# FRONTEND_ORIGIN: The origin domain of your frontend app for CORS configuration (if different from the backend URL).
FRONTEND_ORIGIN=

# SMTP Email Verification Settings
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER="YOUR_EMAIL@gmail.com"
SMTP_PASS="YOUR_GMAIL_APP_PASSWORD"
EMAIL_FROM="Azure Dental Clinic <YOUR_EMAIL@gmail.com>"
